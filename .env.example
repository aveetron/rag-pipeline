POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
RABBITMQ_HOST=
RABBITMQ_PORT=
RABBITMQ_USER=
RABBITMQ_PASSWORD=
RABBITMQ_VHOST=
EXCHANGE_NAME=rag.events
RABBITMQ_QUEUE_NAME=rag.tasks
UPLOAD_DIR=data/uploads
MAX_UPLOAD_BYTES=20971520
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=
QDRANT_HTTPS=false
QDRANT_PREFER_GRPC=false
# Ollama OpenAI-compatible API: use /v1 (not /api/generate)
LLM_BASE_URL=http://127.0.0.1:11434/v1
LLM_MODEL=phi3:mini
LLM_API_KEY=
# Read timeout for Ollama (local models can be slow); increase if needed
LLM_TIMEOUT_SECONDS=300
# Truncate retrieved context to speed up time-to-first-token (lower = faster)
MAX_RAG_CONTEXT_CHARS=12000